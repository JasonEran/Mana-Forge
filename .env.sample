# Mana runtime configuration
# Copy this file to .env at the repository root. Process environment variables
# override values in this file. Never commit a .env file with real secrets.

# Local-only is the safe default. OPENAI_API_KEY is ignored unless this is 1.
MANA_ALLOW_REMOTE_AI=0

# Local backend lifecycle. The launcher derives the backend port from this URL.
MANA_BACKEND_URL=http://127.0.0.1:5005
MANA_BACKEND_STARTUP_TIMEOUT_MS=30000
MANA_BACKEND_SHUTDOWN_TIMEOUT_MS=5000

# Local runtimes are auto-discovered under tools/ when these are unset.
# Set explicit paths only to override discovery.
# WHISPER_BIN=C:\path\to\whisper-cli.exe
# WHISPER_MODEL=C:\path\to\ggml-base.en.bin
# LLAMA_BIN=C:\path\to\llama-cli.exe
# LLAMA_SERVER_BIN=C:\path\to\llama-server.exe
# LLAMA_MODEL=C:\path\to\Qwen3-4B-Q4_K_M.gguf
LLAMA_NGL=99

# Kokoro is the supported default TTS provider for v0.3.
TTS_PROVIDER=kokoro
KOKORO_TTS_URL=http://127.0.0.1:5011
# Optional: override the 60s installed / 10m first-setup readiness timeout.
# MANA_KOKORO_STARTUP_TIMEOUT_MS=60000
MANA_KOKORO_SHUTDOWN_TIMEOUT_MS=10000
CHATTERBOX_TTS_URL=http://127.0.0.1:5010
FISH_TTS_URL=http://127.0.0.1:8080

# Optional remote AI escape hatch. Set only when intentionally enabled above.
# OPENAI_API_KEY=sk-YOUR_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=your-model

# Optional mobile companion. Generate real values before enabling it.
# MOBILE_PASSCODE_HASH=pbkdf2_sha256$120000$REPLACE_SALT$REPLACE_HASH
# MOBILE_SESSION_SECRET=replace-with-random-hex
MOBILE_SESSION_TTL_MS=43200000
