{
  "name": "local-voice-bot-launcher",
  "version": "0.3.0",
  "description": "Electron launcher for the local AI assistant with wake-word listening",
  "main": "main.js",
  "scripts": {
    "test": "node --test",
    "start": "electron .",
    "dev": "nodemon --config nodemon.json",
    "pack": "electron-builder --dir",
    "prepack": "node scripts/check-release-inputs.js",
    "predist": "node scripts/check-release-inputs.js",
    "dist": "electron-builder --win nsis --publish never",
    "verify:package": "node scripts/verify-launcher-package.js",
    "verify:installer": "node scripts/verify-installer.js",
    "verify:branding": "node scripts/verify-windows-branding.js",
    "smoke:installer": "powershell -ExecutionPolicy Bypass -File ../scripts/windows-installer-smoke.ps1",
    "measure:core-release": "node scripts/run-core-release-smoke.js",
    "test:avatar-visual": "node scripts/run-avatar-visual-smoke.js",
    "test:electron-security": "node scripts/run-electron-security-smoke.js"
  },
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "build": {
    "appId": "com.mana.ai",
    "productName": "Mana",
    "artifactName": "Mana-Setup-${version}-${arch}.${ext}",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!test{,/**}",
      "!scripts{,/**}",
      "!nodemon.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    },
    "extraResources": [
      {
        "from": "../node-bot",
        "to": "node-bot",
        "filter": [
          "**/*",
          "!test{,/**}",
          "!scripts{,/**}",
          "!tmp{,/**}",
          "!data{,/**}",
          "!*.log"
        ]
      },
      {
        "from": "../node-bot/node_modules",
        "to": "node-bot/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../tts-service",
        "to": "tts-service",
        "filter": [
          "**/*",
          "!venv{,/**}",
          "!kokoro{,/**}",
          "!__pycache__{,/**}",
          "!*.wav",
          "!*.mp3"
        ]
      },
      {
        "from": "../node-bin",
        "to": "node_bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "nodemon": "^3.1.14",
    "resedit": "^1.7.2"
  }
}
