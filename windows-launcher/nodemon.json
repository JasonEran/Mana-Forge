{
  "watch": [
    "main.js",
    "preload.js",
    "avatar-preload.js",
    "electron-security.js",
    "renderer",
    "avatar",
    "assets/avatar",
    "../node-bot"
  ],
  "ext": "js,json,html,css,md",
  "ignore": [
    "../node-bot/tmp/**",
    "../node-bot/node_modules/**",
    "node_modules/**"
  ],
  "delay": "500",
  "exec": "electron ."
}
